generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LoginStatus {
  SUCCESS
  FAILED
}

model Lead {
  id                 Int      @id @default(autoincrement())
  employeeId         String
  agentName          String?
  clientEmail        String
  leadEmail          String
  ccEmail            String? // Keep original name
  subjectLine        String
  emailPitch         String
  emailResponce      String?
  website            String?
  phone              String? // Keep original name
  country            String?
  leadType           String
  date               DateTime
  createdAt          DateTime @default(now())
  employee           Employee @relation(fields: [employeeId], references: [employeeId])
  link               String
  isEdited           Boolean? @default(false)
  forwarded          Boolean  @default(false)
  qualified          Boolean?
  attendeesCount     Int? // New field
  salesEmployeeId    Int?
  salesEmployeeName  String?
  salesEmployeeEmail String?
  statusId           Int?

  forwardedToSales Boolean        @default(false)
  forwardedAt      DateTime?
  status           LeadStatus?    @relation(fields: [statusId], references: [id], onDelete: SetNull)
  salesEmployee    SalesEmployee? @relation(fields: [salesEmployeeId], references: [id], onDelete: SetNull)
}

model Employee {
  id                Int                 @id @default(autoincrement())
  employeeId        String              @unique
  fullName          String
  email             String              @unique
  password          String
  role              String              @default("EMPLOYEE")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime?           @updatedAt
  target            Int                 @default(0)
  joiningDate       DateTime
  isActive          Boolean             @default(true)
  leads             Lead[]
  sessions          Session[]
  loginHistory      LoginHistory[]
  mailDomains       EmailDomain[]
  sharedLinks       SharedLink[]        @relation("CreatedLinks") // Links created by admin
  receivedLinks     ReceivedLink[]      @relation("ReceivedByEmployee") // Links received by employee
  Notification      Notification[]
  pushSubscriptions PushSubscription[]
  dealInfos         DealInfo[]
  //EmployeeLeadTarget EmployeeLeadTarget?
  leadTarget        EmployeeLeadTarget?

  @@index([role])
  @@index([isActive])
  @@index([employeeId])
}

model Quote {
  id       Int     @id @default(autoincrement())
  text     String  @db.Text
  author   String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model SharedLink {
  id Int @id @default(autoincrement())

  /// OLD FIELD (kept to avoid data loss)
  /// ✨ You will remove this *after* migrating old data safely.
  link String? @db.Text

  linkType String
  country  String

  message           String? @db.Text // ⭐ NEW FIELD (THIS IS THE CORE)
  sharedEmployeeIds String? // "12,15,22"

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  createdById Int
  createdBy   Employee @relation("CreatedLinks", fields: [createdById], references: [id], onDelete: Cascade)

  // NEW MULTI-URL RELATION
  urls SharedLinkUrl[] @relation("SharedLink_Urls")

  // Existing recipients
  recipients ReceivedLink[] @relation("LinkRecipients")

  @@index([createdById])
  @@index([linkType])
  @@index([country])
  @@index([createdAt])
}

model SharedLinkUrl {
  id           Int    @id @default(autoincrement())
  url          String @db.Text
  sharedLinkId Int

  sharedLink SharedLink @relation("SharedLink_Urls", fields: [sharedLinkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ReceivedLink {
  id Int @id @default(autoincrement())

  sharedLinkId Int
  sharedLink   SharedLink @relation("LinkRecipients", fields: [sharedLinkId], references: [id], onDelete: Cascade)

  recipientId Int
  recipient   Employee @relation("ReceivedByEmployee", fields: [recipientId], references: [id], onDelete: Cascade)

  receivedDate DateTime @default(now())

  isSeen Boolean   @default(false)
  isRead Boolean   @default(false)
  seenAt DateTime?

  isOpen   Boolean   @default(false)
  openedAt DateTime?

  @@unique([sharedLinkId, recipientId])
  @@index([recipientId])
  @@index([sharedLinkId])
  @@index([receivedDate])
}

model Industry {
  id           Int      @id @default(autoincrement())
  employeeId   String
  fullName     String
  createdAt    DateTime @default(now())
  industryName String
  leadType     String
  countryName  String
}

model Notification {
  id      Int     @id @default(autoincrement())
  userId  Int
  title   String
  message String?
  link    String?
  type    String  @default("info")

  isRead Boolean @default(false)

  // 🔒 NEW FIELDS (SAFE)
  isDismissed Boolean   @default(false) // ⭐ important
  dismissedAt DateTime?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user Employee @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isDismissed])
}

model IncentivePlan {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  icon        String
  accentColor String
  bgAccent    String

  isActive  Boolean   @default(true)
  validFrom DateTime  @default(now())
  validTo   DateTime?

  rules IncentiveRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncentiveRule {
  id Int @id @default(autoincrement())

  leadType          String
  country           String?
  attendeesMinCount Int?
  industryDomain    String?

  leadsRequired Int
  amount        Int

  isActive Boolean @default(true)

  incentivePlanId Int
  incentivePlan   IncentivePlan @relation(fields: [incentivePlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user Employee @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SalesEmployee {
  id       Int     @id @default(autoincrement())
  fullName String
  email    String  @unique
  phone    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  leads Lead[]

  @@index([isActive])
}

model EmailDomain {
  id         Int      @id @default(autoincrement())
  employeeId String
  email      String
  domain     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId])
  @@index([isActive])
}

model LeadStatus {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]
}

model DealInfo {
  id Int @id @default(autoincrement())

  clientEmail String

  // OLD (keep for backward compatibility)
  industry   String
  leadType   String
  dealStatus String

  // ✅ INDEPENDENT RELATIONS
  industryId    Int?
  eventId       Int?
  associationId Int?

  industryRef    IndustryMaster?    @relation(fields: [industryId], references: [id])
  eventRef       EventMaster?       @relation(fields: [eventId], references: [id])
  associationRef AssociationMaster? @relation(fields: [associationId], references: [id])

  month Int?
  year  Int?

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  manualAgentName  String?
  manualAgentId    String?
  manualAgentEmail String?

  // ✅ NEW
  agentResolved Boolean @default(false)

  // ✅ NEW
  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientEmail])
  @@index([employeeId])
  @@index([createdAt])
  @@index([industryId])
  @@index([eventId])
  @@index([associationId])
  @@index([agentResolved])
  // ✅ OPTIONAL BUT RECOMMENDED
  @@index([month, year])
  // ✅ OPTIONAL BUT GOOD FOR FILTERING
  @@index([dealStatus])
}

model IndustryMaster {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  DealInfo    DealInfo[]
  EventMaster EventMaster[]

  @@index([isActive])
}

model EventMaster {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals            DealInfo[]
  IndustryMaster   IndustryMaster? @relation(fields: [industryMasterId], references: [id])
  industryMasterId Int?

  @@index([isActive])
}

model AssociationMaster {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals DealInfo[]

  @@index([isActive])
}

model LeadTypeMaster {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model DealStatusMaster {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model LoginOtp {
  id Int @id @default(autoincrement())

  email String @unique
  otp   String

  attempts Int @default(0)

  expiresAt         DateTime
  resendAvailableAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model EmployeeLeadTarget {
  id Int @id @default(autoincrement())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  associationPercent     Int @default(0)
  attendeesPercent       Int @default(0)
  industryPercent        Int @default(0)
  memberAttendeesPercent Int @default(0) // 👈 NEW FIELD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}

model Session {
  id        Int      @id @default(autoincrement())
  sessionId String?
  userId    Int
  user      Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  token String @unique

  ipAddress String?
  device    String?

  loginTime  DateTime @default(now())
  lastActive DateTime @default(now())

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([isActive])
}

model LoginHistory {
  id String @id @default(uuid())

  userId Int?
  user   Employee? @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeId   String
  employeeName String
  email        String

  ipAddress String?
  isp       String?
  location  String?

  latitude  Float?
  longitude Float?

  browser        String?
  browserVersion String?
  os             String?
  deviceType     String? // desktop / mobile / tablet
  deviceId       String?

  sessionId String?

  loginTime  DateTime  @default(now())
  logoutTime DateTime?

  sessionDuration Int? // seconds

  status LoginStatus

  otpVerified Boolean @default(false)

  loginMethod String? // Password + OTP

  attemptCount Int @default(1)

  suspiciousFlag Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([employeeId])
  @@index([email])
  @@index([loginTime])
  @@index([status])
}

model AllowedIP {
  id        String   @id @default(uuid())
  ipAddress String   @unique
  label     String?
  status    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([status])
}
